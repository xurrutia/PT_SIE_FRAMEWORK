int GetParentID(int myID)
{


  string strServerName = getSystemName();
  dyn_string ParentNumbers;
  dpGet(strServerName + \"_PanelTopology.parentNumber:_online.._value\", ParentNumbers);

int val;
//DebugTN(\"myID\",myID,\"(int)ParentNumbers[myID]\",(int)ParentNumbers[myID]);
if(myID ==1)
   val=0;
else if(myID ==-1)
{
 // DebugTN(\"my ID is -1\");
     val=-1;
   }
else
  val= (int)ParentNumbers[myID];

  return val;

}

