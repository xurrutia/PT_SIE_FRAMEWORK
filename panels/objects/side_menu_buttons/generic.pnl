int iMyScreenNumber = GetMyScreenNumber(); //get out the screen number


public shared_ptr<GUINaviButtonCollection> GetGuiNaviButtonCollection()
{
  return daCollection[iMyScreenNumber];
}

dyn_int GetMyChildrenAndGrands(int currentParentIndex)
{
  //  DebugTN(\"currentParentIndex\", currentParentIndex);
    string strServerName = getSystemName();
    dyn_uint ParentNumbers;
    dyn_int childIndices;

    dpGet(strServerName + \"_PanelTopology.parentNumber:_online.._value\", ParentNumbers);

    for (int i = 1; i <= dynlen(ParentNumbers); i++)
    {

        if (ParentNumbers[i] == currentParentIndex)
        {
            childIndices.append(i);

        //recursive loop
            dyn_int grandChildren = GetMyChildrenAndGrands(i);
            for (int j = 1; j <= dynlen(grandChildren); j++)
            {
                childIndices.append(grandChildren[j]);
            }
        }
    }

 // DebugTN(\"childIndices\", childIndices);
    return childIndices;
}


dyn_int GetMyChildren(int currentParentIndex)
{
 // DebugTN(\"currentParentIndex\", currentParentIndex);
  string strServerName = getSystemName();
  dyn_uint ParentNumbers;
  dyn_int childIndecies;
  dpGet(strServerName + \"_PanelTopology.parentNumber:_online.._value\", ParentNumbers);

  for (int i = 1; i <= dynlen(ParentNumbers); i++)
  {
  //  DebugTN(\"i=\", i);

    if (ParentNumbers[i]==currentParentIndex)
    {

      childIndecies.append(i);

    }


  }

//\"System1:_PanelTopology.parentNumber\"
 // DebugTN(\"childIndecies\",childIndecies);
  return childIndecies;

}

void LoadMyChildPanels()
{

  string strServerName = getSystemName();
  string moduleName = myModuleName(); //\"naviModule_1\"; /*\"_QuickTest_\";*/
  string panelName = rootPanel(moduleName);//\"Navi\";/*\"para/PanelTopology/templates/SIE/naviPanel_1024_768_SIE.pnl\";*/
  int parentID = (int)$nodeId;
  dyn_int myChildrensIndecies = GetMyChildren(parentID);
  //DebugTN(\"myChildrensIndecies\", myChildrensIndecies);

  for (int i =dynlen(myChildrensIndecies); i>=1 ; i--) //1 because ignore start/root node
  {
   // DebugTN(\"myChildrensIndecies[i]\", myChildrensIndecies[i]);
   //// DebugTN(\"currentParentPosition\",parentID);

   // DebugTN(\"requiredChilePosition\",requiredChilePosition);
   /* addSymbol(moduleName, panelName, \"objects/side_menu_buttons/generic.pnl\", \"navi_btn_\" + myChildrensIndecies[i], parentID+1, moduleName + \".\" + panelName + \":\" + \"LAYOUT_GROUP1\",
              makeDynString(\"$nodeId:\" + myChildrensIndecies[i], \"$bParentNode:\" + false, \"$bSubNode:\" + true));
*/

    //17/11/2025 removed the online value from the \"_PanelTopology.**
    PT_SIEM_addNaviButton(myChildrensIndecies[i], g_PanelTopologyCache[strServerName + \"_PanelTopology.parentNumber:_online.._value\"][myChildrensIndecies[i]]/*, daCollection[iMyScreenNumber]*/);


  /*shape tmp = getShape(myModuleName(),panelName, \"navi_btn_\" + myChildrensIndecies[i]);
  DebugTN(\"tmp\",tmp);
   ButtonCollection.Append(tmp.GetGUINaviButton());*/
  }


}



void RemoveMyChildPanels()
{

 string strServerName = getSystemName();
  string moduleName = myModuleName(); //\"naviModule_1\"; /*\"_QuickTest_\";*/
  string panelName = rootPanel(moduleName);//\"Navi\";/*\"para/PanelTopology/templates/SIE/naviPanel_1024_768_SIE.pnl\";*/
  int parentID = (int)$nodeId;
  dyn_int myChildrensIndecies = GetMyChildrenAndGrands(parentID);
//DebugTN(\"myChildrensIndecies\",myChildrensIndecies);
PT_SIEM_removeNaviButton(parentID,myChildrensIndecies);/*, daCollection[iMyScreenNumber];*/


}
