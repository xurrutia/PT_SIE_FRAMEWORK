main()
{
  this.text = \"\";
  string finalText = \"\";
  this.visible = false;

  if ((bool)$bSubNode == FALSE)
  {

    this.text = \"\";
    this.visible = false;

  }
  else
  {

   // int nodeLevel =(int) $iSubNodeLevel;
//DebugTN(\"debugging the level from the button\",nodeLevel);

      int myID = (int)$nodeId;
      int parentID = getLevel(myID);
     // DebugTN(\"parentID\",parentID);
    for (int i = 1 ; i <= parentID; i++)
    {
      finalText =finalText+ \"   \";

    }


    this.text=finalText;
          this.visible = true;

  }

}


int getLevel(int myID)
{
    string strServerName = getSystemName();
    dyn_uint parentNumbers;
    dpGet(strServerName + \"_PanelTopology.parentNumber:_online.._value\", parentNumbers);

    int level = 0;
    int currentID = myID;

    while (1)
    {
        int parentID = parentNumbers[currentID];

        // Top-level panel has parentNumber 1 (or 0 depending on your topology)
        if (parentID <= 1)
        {
            level += 1;  // count this level
            break;
        }

        // Move up to parent
        currentID = parentID;
        level += 1;
    }

    //DebugTN(\"Panel level for ID \" + myID, level);
    return level;
}

